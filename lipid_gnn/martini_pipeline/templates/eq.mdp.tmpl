; Equilibration MDP — Martini 3 lipid bilayer
; Generated by lipid_gnn.martini_pipeline.mdp_writer
;
; Deliberately diverges from legacy in three ways (Decision 14):
;   compressibility 3e-4 3e-4  (legacy 3e-5 — too slow for novel compositions)
;   nsteps 1 000 000 / 10 ns  (legacy 250 000 / 2.5 ns — often too short)
;   nstenergy 1000             (legacy 100 — I/O reduction on long auto-runs)
; All other values are from the audit canonical (docs/mdp_audit_report.md).

integrator               = md
dt                       = 0.01
nsteps                   = ${nsteps_eq}             ; [CONFIG: nsteps_eq]
nstcomm                  = 100

nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstlog                   = 1000
nstenergy                = ${nstenergy_eq}          ; [CONFIG: nstenergy_eq]
nstxout-compressed       = 1000
compressed-x-precision   = 100
nstcalcenergy            = 100

cutoff-scheme            = Verlet
nstlist                  = 20
pbc                      = xyz
verlet-buffer-tolerance  = 0.005

coulombtype              = Cut-off
coulomb-modifier         = Potential-shift
rcoulomb                 = 1.1
epsilon-r                = 15

vdw-type                 = Cut-off
vdw-modifier             = Potential-shift
rvdw                     = 1.1

; Temperature — V-rescale with 1 ps coupling
tcoupl                   = V-rescale
tc-grps                  = System
tau-t                    = 1.0
ref-t                    = 310                      ; [CONFIG: future — currently fixed]

; Pressure — Berendsen semiisotropic (stable during equilibration)
; compressibility deliberately set to 3e-4 (Martini 3 canonical for membranes);
; the legacy value of 3e-5 is ~10x too stiff for tau-p = 5 ps Berendsen.
pcoupl                   = Berendsen
pcoupltype               = semiisotropic
tau-p                    = 5.0
compressibility          = 3e-4 3e-4               ; [CONFIG: future — currently fixed]
ref-p                    = 1.0 1.0

; Fresh velocity generation — independent of minimization output
gen-vel                  = yes
gen-temp                 = 310                      ; [CONFIG: future — currently fixed]
gen-seed                 = ${gen_seed}              ; [CONFIG: gen_seed]

constraints              = none
dispcorr                 = No
comm-mode                = Linear
refcoord-scaling         = No
