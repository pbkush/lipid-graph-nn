; Energy minimisation MDP — Martini 3 lipid bilayer
; Generated by lipid_gnn.martini_pipeline.mdp_writer
; Canonical values derived from audit of 70 legacy systems (docs/mdp_audit_report.md).

integrator               = steep
dt                       = 0.001
nsteps                   = ${nsteps_min}            ; [CONFIG: nsteps_min]
emtol                    = 10
emstep                   = 0.01

nstcomm                  = 100
nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstlog                   = 1000
nstenergy                = 100
nstxout-compressed       = 1000
compressed-x-precision   = 100
nstcalcenergy            = 100

cutoff-scheme            = Verlet
nstlist                  = 20
pbc                      = xyz
verlet-buffer-tolerance  = 0.005

coulombtype              = Cut-off
coulomb-modifier         = Potential-shift
rcoulomb                 = 1.1
epsilon-r                = 15

vdw-type                 = Cut-off
vdw-modifier             = Potential-shift
rvdw                     = 1.1

tcoupl                   = No
pcoupl                   = No

constraints              = none
dispcorr                 = No
comm-mode                = Linear
